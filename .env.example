# ─── Exchange (Binance) ──────────────────────────────────────────
EXCHANGE_NAME=binance
EXCHANGE_API_KEY=your_binance_api_key_here
EXCHANGE_API_SECRET=your_binance_api_secret_here

# ─── Live vs Simulation ──────────────────────────────────────────
# Set to "false" to execute REAL trades on Binance.
# Keep "true" to run in paper trading / simulation mode.
SIMULATION_MODE=true

# ─── Groq AI (for sentiment veto) ───────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# ─── Discord Alerts (optional) ──────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here
